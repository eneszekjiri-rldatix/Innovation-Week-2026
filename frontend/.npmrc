# Default registry: all packages go through Nexus (company proxy).
# Exception: @rld-engineering scope goes directly to GitHub Packages.
# Auth token for GitHub Packages must be set in your local ~/.npmrc (never committed):
#   //npm.pkg.github.com/:_authToken=YOUR_GITHUB_PAT
#
# See ROADMAP.md INFRA-002 for the long-term plan to proxy @rld-engineering through Nexus too.
registry=https://nexus.allocate-cloud.co.uk/repository/npm-group/
@rld-engineering:registry=https://npm.pkg.github.com